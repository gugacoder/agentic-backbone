# ── App
ENVIRONMENT=development
NODE_ENV=development
VITE_ENV=development

# ── Project Identity and Parameters
PROJECT=agentic-backbone
TIMEZONE=America/Sao_Paulo
CONTEXT_FOLDER=./context

# ══════════════════════════════════════════════════════════════════════
# Mapeamento de portas e hosts
# ── Port Parameters
PREFIX=60
PUBLIC_PORT=${PREFIX}00
# ── Source Ports
HUB_PORT=${PREFIX}01
BACKBONE_PORT=${PREFIX}02
CHAT_PORT=${PREFIX}03
# ── Service Ports
POSTGRES_PORT=5432
REDIS_PORT=6379
EVOLUTION_PORT=8080
WHISPER_PORT=9095
NGROK_PORT=4040
ADMINER_PORT=8080
# ── Source Hosts
HUB_HOST=hub.internal
CHAT_HOST=chat.internal
BACKBONE_HOST=backbone.internal
# ── Service Hosts
POSTGRES_HOST=postgres.internal
REDIS_HOST=redis.internal
EVOLUTION_HOST=evolution.internal
WHISPER_HOST=whisper.internal
NGROK_HOST=ngrok.internal
ADMINER_HOST=adminer.internal
# ── Callbacks
BACKBONE_CALLBACK_HOST=backbone.internal
# ══════════════════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════════════════
# DEV OVERRIDES - Use somente em modo desenvolvimento
# ── Proxy (Caddy dentro do Docker alcança apps no host)
PROXY_UPSTREAM=host.docker.internal
# ── Service Ports
POSTGRES_PORT=${PREFIX}10
REDIS_PORT=${PREFIX}11
EVOLUTION_PORT=${PREFIX}12
WHISPER_PORT=${PREFIX}14
NGROK_PORT=${PREFIX}15
ADMINER_PORT=${PREFIX}13
# ── Source Hosts
HUB_HOST=localhost
CHAT_HOST=localhost
BACKBONE_HOST=localhost
# ── Service Hosts
POSTGRES_HOST=localhost
REDIS_HOST=localhost
EVOLUTION_HOST=localhost
WHISPER_HOST=localhost
NGROK_HOST=localhost
ADMINER_HOST=localhost
# ── Callbacks
BACKBONE_CALLBACK_HOST=host.docker.internal
# ══════════════════════════════════════════════════════════════════════

# ── Autenticacao
JWT_SECRET=backbone-dev-jwt-secret-change-in-production-2026
ENCRYPTION_KEY=backbone-dev-jwt-secret-change-in-production-2026

# ── Test credentials (for test scripts)
TEST_USER=admin@mail.com
TEST_PASS=12345678

# ── API Keys (gerenciadas via context/settings.yml providers section)
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
# GROQ_API_KEY=gsk_your-groq-api-key
# OPENAI_API_KEY=sk-proj-your-openai-api-key

# ── Evolution (WhatsApp)
EVOLUTION_URL=http://${EVOLUTION_HOST}:${EVOLUTION_PORT}
EVOLUTION_API_KEY=evolution-key
EVOLUTION_TYPING_MS_PER_CHAR=15
# ── Postgres para uso do Evolution
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Whisper e ngrok → configurar em context/settings.yml (infrastructure.whisper / infrastructure.ngrok)

# ── ElevenLabs (Text-to-Speech)
# ELEVENLABS_API_KEY=sk_your-elevenlabs-api-key
# ELEVENLABS_VOICE_ID=your-voice-id

# ── Brave Web Search API
# BRAVE_API_KEY=your-brave-api-key

# ── Twilio (Voice)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
