{
  "name": "agentic-backbone",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/packages/*",
    "apps/packages/gitlab/v4"
  ],
  "scripts": {
    "printenv": "dotenv -o -e .env -- printenv",
    "killports": "node scripts/killports.mjs",
    "dev:all": "concurrently -n hub,backbone -c blue,green \"npm run dev:hub\" \"npm run dev:backbone\" 2>&1 | tee .tmp/-run.log",
    "dev:backbone": "npm run dev --workspace=apps/backbone",
    "dev:hub": "npm run dev --workspace=apps/hub",
    "dev:web": "npm run dev --workspace=apps/web",
    "platform:up": "node scripts/platform.mjs up -d",
    "platform:down": "node scripts/platform.mjs down",
    "platform:ps": "node scripts/platform.mjs ps",
    "platform:logs": "node scripts/platform.mjs logs -f",
    "docker:build": "dotenv -o -e .env -- docker compose build --no-cache",
    "docker:up": "dotenv -o -e .env -- docker compose up -d",
    "docker:down": "dotenv -o -e .env -- docker compose down",
    "docker:ps": "dotenv -o -e .env -- docker compose ps",
    "docker:logs": "dotenv -o -e .env -- docker compose logs -f",
    "build": "npm run build --workspace=apps/packages/ai-sdk && npm run build --workspace=apps/packages/gitlab/v4 && npm run build --workspace=apps/backbone && npm run build --workspace=apps/hub && npm run build --workspace=apps/web",
    "build:packages": "npm run build --workspace=apps/packages/ai-sdk && npm run build --workspace=apps/packages/gitlab/v4",
    "build:hub": "npm run build --workspace=apps/hub",
    "build:web": "npm run build --workspace=apps/web",
    "test:conversation": "dotenv -o -e .env -- node tests/test-conversations.mjs",
    "test:capabilities": "dotenv -o -e .env -- node tests/capabilities/run-all.mjs",
    "test:capabilities:hooks": "dotenv -o -e .env -- node tests/capabilities/test-conversation-hooks.mjs",
    "test:capabilities:skills": "dotenv -o -e .env -- node tests/capabilities/test-conversation-skills.mjs",
    "test:capabilities:memory": "dotenv -o -e .env -- node tests/capabilities/test-conversation-memory.mjs",
    "test:capabilities:tools": "dotenv -o -e .env -- node tests/capabilities/test-conversation-tools.mjs",
    "test:capabilities:cron": "dotenv -o -e .env -- node tests/capabilities/test-conversation-cron.mjs",
    "test:capabilities:jobs": "dotenv -o -e .env -- node tests/capabilities/test-conversation-jobs.mjs",
    "test:capabilities:identity": "dotenv -o -e .env -- node tests/capabilities/test-conversation-identity-and-context.mjs",
    "test:e2e": "npx playwright test",
    "test:e2e:hub": "npx playwright test --project=hub",
    "secrets:decrypt": "node scripts/secrets.mjs decrypt",
    "secrets:encrypt": "node scripts/secrets.mjs encrypt",
    "ngrok:up": "dotenv -o -e .env -- npx ngrok http 6002"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0"
  },
  "dependencies": {
    "agentic-backbone": "file:"
  }
}
