# Agentic Backbone — Production
# Copiar para deploy/.env e preencher secrets

ENVIRONMENT=production
NODE_ENV=production
VITE_ENV=production

PROJECT=agentic-backbone
TIMEZONE=America/Sao_Paulo
PUBLIC_DOMAIN=ab.codr.studio

# ── Portas
PREFIX=60
BACKBONE_PORT=6002

# ── Secrets (preencher!)
JWT_SECRET=
ENCRYPTION_KEY=
OPENROUTER_API_KEY=

# ── Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres.internal
POSTGRES_PORT=5432

# ── Redis
REDIS_HOST=redis.internal
REDIS_PORT=6379

# ── Evolution (WhatsApp) — opcional
# EVOLUTION_URL=http://evolution.internal:8080
# EVOLUTION_API_KEY=
